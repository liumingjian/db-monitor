{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "preserve",
		"lib": ["dom", "dom.iterable", "es2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["node", "vitest/globals"]
	},
	"include": [
		"app/**/*.ts",
		"app/**/*.tsx",
		"next-env.d.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		"tests/**/*.ts",
		"vitest.config.ts"
	]
}
