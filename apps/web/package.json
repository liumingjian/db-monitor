{
	"name": "web",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "next build",
		"dev": "next dev",
		"lighthouse:ci": "node tests-e2e/lighthouse-runner.mjs",
		"lint": "biome check app src tests tests-e2e next-env.d.ts next.config.ts package.json playwright.config.ts tsconfig.json vitest.config.ts",
		"smoke": "vitest run smoke",
		"test": "vitest run",
		"test:e2e": "playwright test --config playwright.config.ts",
		"test:e2e:update": "playwright test --config playwright.config.ts --update-snapshots",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@db-monitor/api-client": "workspace:*",
		"@db-monitor/ui": "workspace:*",
		"@fontsource/ibm-plex-sans": "^5.2.8",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@fontsource/noto-sans-sc": "^5.2.9",
		"@tanstack/react-query": "^5.99.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"echarts": "^6.0.0",
		"lucide-react": "^1.8.0",
		"next": "^16.2.4",
		"next-intl": "^4.9.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@tailwindcss/postcss": "^4.2.2",
		"@types/node": "^24.10.0",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.2.3",
		"postcss": "^8.5.10",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
